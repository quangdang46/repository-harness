{
  "name": "harness-benchmark",
  "version": "1.0.0",
  "description": "Benchmark project for measuring harness-experimental effectiveness",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "harness-bench": "tsx benchmark/orchestrator/interface/cli.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck:orchestrator": "tsc -p tsconfig.orchestrator.json",
    "lint:orchestrator": "vitest run benchmark/orchestrator/test/architecture-boundaries.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.21.0",
    "better-sqlite3": "^11.6.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
